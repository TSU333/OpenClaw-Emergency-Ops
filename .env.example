APP_NAME=OpenClaw Emergency Ops
APP_ENV=development
API_PREFIX=/api/v1
TIMEZONE=Australia/Melbourne

DATABASE_URL=postgresql+psycopg://openclaw:openclaw@postgres:5432/openclaw_ops
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

AUTO_CREATE_TABLES=true
ENABLE_BACKGROUND_ESCALATION=true
CELERY_TASK_ALWAYS_EAGER=false

APPRISE_ENABLED=true
DEFAULT_PRIMARY_CONTACT_NAME=Primary Operator
DEFAULT_PRIMARY_CONTACT_ROLE=operator
DEFAULT_PRIMARY_APPRISE_TARGETS=tgram://bot_token/chat_id
DEFAULT_PRIMARY_PHONE_NUMBER=+61000000000

DEFAULT_SECONDARY_CONTACT_NAME=Secondary Operator
DEFAULT_SECONDARY_CONTACT_ROLE=backup
DEFAULT_SECONDARY_APPRISE_TARGETS=discord://webhook_id/webhook_token
DEFAULT_SECONDARY_PHONE_NUMBER=+61000000001

ESCALATION_FIRST_WAIT_SECONDS=300
ESCALATION_SECOND_WAIT_SECONDS=600

OPENCLAW_VOICE_CALL_URL=
OPENCLAW_VOICE_CALL_TOKEN=
OPENCLAW_VOICE_CALL_TIMEOUT_SECONDS=10

PAUSE_STRATEGY_ENDPOINT=
CLOSE_POSITIONS_ENDPOINT=
RESTART_SERVICE_ENDPOINT=
